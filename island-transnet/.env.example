# Example environment variables
# Copy this to .env and fill in your values

# OpenAI-compatible API key or local placeholder
OPENAI_API_KEY=local-llama-server

# OpenAI-compatible base URL for llama-server
OPENAI_BASE_URL=http://localhost:13595/v1

# Model alias exposed by llama-server
OPENAI_MODEL=ACTION

# Database path (optional, defaults to data/transnet.db)
DATABASE_PATH=data/transnet.db

# JWT secret (used later when auth is added)
JWT_SECRET=change-me-before-auth

# Logging level (optional, defaults to info)
RUST_LOG=info

# Server port (optional, defaults to 8080)
SERVER_PORT=8080

# Number of workers (optional, defaults to 4)
WORKERS=4
