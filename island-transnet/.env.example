# Transnet Backend Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration (OpenAI-compatible)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=http://localhost:13595/v1
OPENAI_MODEL=ACTION

# Server Configuration (optional - defaults in config/*.toml)
# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8080
# BACKEND_URL=http://127.0.0.1:35792

# Logging
RUST_LOG=info
